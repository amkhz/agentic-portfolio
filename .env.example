# Site URL for metadata
VITE_SITE_URL=https://justinh.design

# API base URL (for future integrations)
VITE_API_URL=/api

# Last.fm (server-side only -- consumed by api/lastfm.ts in production
# and the Vite dev proxy mirror locally; never exposed to the client)
LASTFM_API_KEY=your-lastfm-api-key
LASTFM_USER=your-lastfm-username
