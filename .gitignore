node_modules/
dist/
.env
.env.local
.DS_Store
*.log
*.tsbuildinfo

# Agent harness worktrees (transient, per-agent git worktrees).
.claude/worktrees/
.impeccable/

# Wallace render output (local image generation; self-ignored, kept out of the repo).
# Exception: the Flight Deck direction probes are a versioned design record
# (Works 01 phase gate; sidecar captions are the spec phase 2 reads).
/mocks/*
!/mocks/flight-deck-probes/

# Scratchpad — local working files, internal receipts, temp specimens. Never commit
# (the repo is public; internal PR/ADR numbers and metrics must stay out).
/scratchpad/

# Generated responsive image variants (npm run generate:images, run at build).
# The source PNG/JPEG stays committed as the <picture> fallback; only the
# derived AVIF/WebP width-steps are emitted and ignored. The manifest that
# indexes them (core/images/manifest.generated.ts) IS committed.
/public/images/*-[0-9]*.avif
/public/images/*-[0-9]*.webp
