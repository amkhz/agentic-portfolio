{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["vite/client"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"],
      "@core/*": ["./core/*"],
      "@services/*": ["./services/*"],
      "@design-system/*": ["./design-system/*"],
      "@lab/*": ["./src/lab/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "core/**/*.ts",
    "services/**/*.ts",
    "design-system/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
